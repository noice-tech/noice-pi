{
  "name": "noice-pi",
  "private": true,
  "description": "Noice Pi packages",
  "license": "MIT",
  "engines": {
    "node": "24.13.0",
    "pnpm": "11.3.0"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "check": "pnpm format:check && pnpm typecheck && pnpm test",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "node --test scripts/*.test.mjs && pnpm -r --if-present test",
    "release:prepare": "node scripts/prepare-release.mjs",
    "release:publish": "node scripts/publish-release.mjs"
  },
  "devDependencies": {
    "oxfmt": "0.59.0"
  }
}
